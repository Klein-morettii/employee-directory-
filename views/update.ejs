<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title> <%= title %> </title>
        <link rel="stylesheet" href="/update.css">
    </head>

    <body>
        <h1 class="heading"> <%= title %> </h1>
        <%- include("partials/errors.ejs") %>
        <form action="/<%= user.id %>/update" method="POST">
            <fieldset>
                <legend>Update</legend>

                <div>
                    <label for="first_name">First Name:</label>
                    <input type="text" name="first_name" id="first_name" value="<%= user.first_name %>" required>
                </div>

                <div>
                    <label for="last_name">Last Name</label>
                    <input type="text" name="last_name" id="last_name" value="<%= user.last_name %>" required>
                </div>

                <div>
                    <label for="dob">DATE OF BIRTH:</label>
                    <input type="date" name="dob" id="dob" min="18" max="75" value="<%= user.dob %>" required>
                </div>

                <div>
                    <label for="phone_no">PHONE NUMBER:</label>
                    <input type="tel" name="phone_no" id="phone_no" value="<%= user.phone_no %>" minlength="10" maxlength="15" required>
                </div>

                <div>
                    <label for="email">E-MAIL:</label>
                    <input type="email" name="email" id="email" value="<%= user.email %>" required>
                </div>

                <div>
                    <label for="bio">BIO:</label>
                    <textarea name="bio" id="bio" placeholder="About the employee" required> <%= user.bio %> </textarea>
                </div>

            </fieldset>
            <button type="submit">UPDATE</button>
        </form>
        <a href="/">BACK</a>
    </body>
</html>