<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="index.css">
</head>

<body>
    <h1 class="heading">
        <%= title %>
    </h1>

    <a href="/create" class="addEmp">Add an Employee</a>
    <% if(locals.user){ %>
        <% user.forEach(users=>{ %>
            <div class="indexContainer">
                <div class="detail">
                    <span>ID</span>
                    <span>: <%= users.id %></span>
                </div>

                <div class="detail">
                    <span>Name</span>
                    <span>: <%= users.firstName %>
                            <%= users.lastName %></span>
                </div>

                <div class="detail">
                    <span>Phone</span>
                    <span>: <%= users.phone %></span>
                </div>

                <div class="detail">
                    <span>Email</span>
                    <span>: <%= users.email %></span>
                </div>

                <div class="detail">
                    <span>ABOUT</span>
                    <span>: <%= users.bio %></span>
                </div>


                    <form action="/<%= users.id %>/delete" method="post" style="display: inline;">
                        <a href="/<%= users.id %>/update" class="indexUpBtn">UPDATE</a>
                        <button type="submit" onclick="return confirm('Are you sure you want to delete this user?')"
                            class="deleteBtn">
                            DELETE
                        </button>
                    </form>

                    
            </div>
            <% }) %>
                <% } %>
</body>

</html>